rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIELD FOCUS - SPORTS ANALYTICS SECURITY RULES (MVP Update)
     * 
     * 인증된 모든 사용자가 대회 및 경기 데이터를 읽고 쓸 수 있도록 허용합니다.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // 대회 목록 및 상세 정보
    match /tournaments/{tournamentId} {
      allow read, write: if isSignedIn();
    }

    // 경기 데이터 (대회에 소속된 경기 포함)
    match /matches/{matchId} {
      allow read, write: if isSignedIn();
      
      // 하위 컬렉션 (이벤트, 성능 지표 등)
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // 팀 및 선수 정보
    match /teams/{teamId} {
      allow read, write: if isSignedIn();
      match /players/{playerId} {
        allow read, write: if isSignedIn();
      }
    }
  }
}